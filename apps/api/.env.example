DATABASE_URL=sqlite:///./engineering_os.db
CORS_ORIGINS=http://localhost:3000
# AI provider: "fake" (default, no key) or "anthropic"
AI_PROVIDER=fake
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6

# Identity & GitHub federation (Alpha-0.8). Leave the OAuth client unset to use the deterministic
# fake provider (local dev / tests need no GitHub app). Set both to enable real GitHub login.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback
WEB_URL=http://localhost:3000
SESSION_COOKIE=eos_session
COOKIE_SECURE=false
# Encryption of OAuth tokens at rest — REQUIRED in production (any high-entropy secret).
# Generate one, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
TOKEN_ENCRYPTION_KEY=
# Legacy single-token publishing fallback (superseded by per-session OAuth credentials)
GITHUB_TOKEN=
